# Telegram bot token from @BotFather (required)
BOT_TOKEN=18907303420:AAHzeHHDuUtkEeBIz484fQUqC2ZQPExUh4I

# Whitelisted admin user id(s). Single id or comma-separated list (required).
# Only these users can control the bot, and only in private chat.
ADMIN_ID=1771248967

# Target group chat id where surveys are published (required before /send).
# Tip: add the bot to the group, send a message, then read the chat id
# (negative number, e.g. -1001234567890) from getUpdates or @userinfobot.
GROUP_CHAT_ID=-1001234567890

# IANA timezone used to interpret deadlines and display times.
TIMEZONE=Asia/Astana

# SQLite database file path.
DATABASE_PATH=bot.db

# Minimum seconds between two /send operations (anti-spam rate limit).
SEND_COOLDOWN_SECONDS=15
