# Copy this file to ".env" and fill in the values.

# Token issued by @BotFather when you create your bot.
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# REQUIRED in practice. Comma-separated Telegram user IDs allowed to create and
# manage surveys in private chat with the bot. Without at least one id, nobody
# can create surveys. Message the bot with /start to see your own id, or use
# @userinfobot.
SUPER_ADMIN_IDS=

# Optional. Path to the SQLite database file. Defaults to "bot.db" in the
# working directory.
DATABASE_PATH=bot.db

# Optional. IANA timezone used to interpret deadlines you type and to display
# times. Defaults to UTC. Example: Asia/Almaty, Europe/Berlin.
TIMEZONE=UTC
